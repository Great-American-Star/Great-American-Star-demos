<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Clean Star - UNITEDSTATES Only</title>
    <style>
        html, body {
            margin: 0;
            padding: 0;
            background: #1a1a2e;
            color: white;
            font-family: 'Courier New', monospace;
            overflow: auto;
            min-height: 100vh;
            min-width: 100vw;
        }

        .container {
            width: 3000px;
            height: 3000px;
            position: absolute;
            top: 0;
            left: 0;
        }

        .star-container {
            position: absolute;
            width: 3000px;
            height: 3000px;
            transform-origin: center;
            transition: transform 0.3s ease;
            left: 0px;
            top: 0px;
        }

        .star-outline {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            pointer-events: none;
        }

        .star-outline svg {
            width: 100%;
            height: 100%;
        }

        .letter {
            position: absolute;
            font-size: 24px;
            font-weight: bold;
            font-family: Georgia, serif;
            color: #ff6b6b;
            cursor: pointer;
            transition: all 0.3s ease;
            user-select: none;
            text-shadow: 0 0 10px rgba(255, 107, 107, 0.5);
        }

        .letter:hover {
            color: #ffd93d;
            transform: scale(1.2);
            text-shadow: 0 0 20px rgba(255, 217, 61, 0.8);
        }

        .letter.highlighted {
            color: #6bcf7f;
            transform: scale(1.3);
            text-shadow: 0 0 25px rgba(107, 207, 127, 1);
            animation: pulse 1s infinite alternate;
        }

        @keyframes pulse {
            from { opacity: 0.8; }
            to { opacity: 1; }
        }

        .controls {
            position: fixed;
            top: 20px;
            left: 20px;
            z-index: 1000;
        }

        .control-btn {
            background: rgba(255, 255, 255, 0.1);
            border: 1px solid rgba(255, 255, 255, 0.3);
            color: white;
            padding: 10px 15px;
            margin: 5px;
            border-radius: 5px;
            cursor: pointer;
            transition: all 0.3s ease;
        }

        .control-btn:hover {
            background: rgba(255, 255, 255, 0.2);
            transform: translateY(-2px);
        }

        .info {
            position: fixed;
            bottom: 20px;
            left: 20px;
            font-size: 14px;
            opacity: 0.7;
        }
    </style>
</head>
<body>
    <div style="position: absolute; top: 0; left: 0; width: 3000px; height: 3000px; z-index: -1;"></div>
    
    <div class="container">
        <div class="star-container" id="starContainer">
            <!-- 5-pointed star outline -->
            <div class="star-outline">
                <svg viewBox="0 0 3000 3000" xmlns="http://www.w3.org/2000/svg">
                    <defs>
                        <filter id="glow">
                            <feGaussianBlur result="coloredBlur" stdDeviation="3"></feGaussianBlur>
                            <feMerge>
                                <feMergeNode in="coloredBlur"></feMergeNode>
                                <feMergeNode in="SourceGraphic"></feMergeNode>
                            </feMerge>
                        </filter>
                    </defs>
                    <!-- 5-pointed star path -->
                    <path d="" fill="none" filter="url(#glow)" id="starPath" stroke="rgba(255, 255, 255, 0.4)" stroke-width="3"></path>
                </svg>
            </div>
        </div>
    </div>

    <div class="controls">
        <button class="control-btn" onclick="zoomIn()">Zoom In</button>
        <button class="control-btn" onclick="zoomOut()">Zoom Out</button>
        <button class="control-btn" onclick="resetZoom()">Reset Zoom</button>
        <button class="control-btn" onclick="animateLetters()">Animate</button>
        <button class="control-btn" onclick="clearHighlights()">Clear Highlights</button>
    </div>

    <div class="info">
        <div>UNITEDSTATES: 12 rings completed</div>
        <div>U(50) N(55) I(60) T(65) E(70) D(75) S(80) T(85) A(90) T(95) E(100) S(105)</div>
        <div>Total: 955 letters</div>
        <div>Click letters to highlight paths</div>
    </div>

    <script>
        let currentZoom = 1;
        let letters = [];
        let highlightedPaths = [];

        function createUNITEDSTATESOnly() {
            const container = document.getElementById('starContainer');
            const centerX = 1500;
            const centerY = 1500;
            const innerRadius = 220;
            const radiusStep = 35;
            
            // Pentagon vertices (tip pointing down)
            function getPentagonVertices(radius) {
                const vertices = [];
                for (let i = 0; i < 5; i++) {
                    const angle = (i * 2 * Math.PI / 5) + (Math.PI / 2);
                    const x = centerX + radius * Math.cos(angle);
                    const y = centerY + radius * Math.sin(angle);
                    vertices.push({x, y});
                }
                return vertices;
            }

            let letterIndex = 0;
            let currentRadius = innerRadius;

            // UNITEDSTATES letter sequence
            const unitedStatesSequence = [
                {letter: 'U', count: 50, color: '#ff6b6b'},
                {letter: 'N', count: 55, color: '#4ecdc4'},
                {letter: 'I', count: 60, color: '#ff9f43'},
                {letter: 'T', count: 65, color: '#10ac84'},
                {letter: 'E', count: 70, color: '#ee5a52'},
                {letter: 'D', count: 75, color: '#0abde3'},
                {letter: 'S', count: 80, color: '#feca57'},
                {letter: 'T', count: 85, color: '#ff6b9d'},
                {letter: 'A', count: 90, color: '#c44569'},
                {letter: 'T', count: 95, color: '#f8b500'},
                {letter: 'E', count: 100, color: '#6c5ce7'},
                {letter: 'S', count: 105, color: '#a29bfe'}
            ];

            unitedStatesSequence.forEach((letterData, ringIndex) => {
                const vertices = getPentagonVertices(currentRadius);
                const lettersPerSide = (letterData.count + 5) / 5;
                
                // Place letters along each side
                for (let side = 0; side < 5; side++) {
                    const startVertex = vertices[side];
                    const endVertex = vertices[(side + 1) % 5];
                    
                    for (let i = 0; i < lettersPerSide; i++) {
                        const t = i / (lettersPerSide - 1);
                        const x = startVertex.x + t * (endVertex.x - startVertex.x);
                        const y = startVertex.y + t * (endVertex.y - startVertex.y);
                        
                        const letter = document.createElement('div');
                        letter.className = 'letter';
                        letter.textContent = letterData.letter;
                        letter.style.left = (x - 12) + 'px';
                        letter.style.top = (y - 12) + 'px';
                        letter.style.color = letterData.color;
                        letter.dataset.index = letterIndex;
                        letter.dataset.type = letterData.letter;
                        
                        letter.addEventListener('click', () => highlightPath(letterIndex));
                        
                        container.appendChild(letter);
                        letters.push(letter);
                        letterIndex++;
                    }
                }

                // Remove duplicate corners
                const toRemove = [];
                for (let side = 1; side < 5; side++) {
                    toRemove.push(letters.length - (5 - side) * lettersPerSide);
                }
                
                toRemove.reverse().forEach(index => {
                    if (letters[index]) {
                        letters[index].remove();
                        letters.splice(index, 1);
                        letterIndex--;
                    }
                });

                currentRadius += radiusStep;
            });

            // Update indices
            letters.forEach((letter, index) => {
                letter.dataset.index = index;
            });
        }

        function createPerfectStar() {
            const centerX = 1495;
            const centerY = 1500;
            const outerRadius = 1600;
            const innerRadius = 602;
            
            const starPoints = [];
            
            for (let i = 0; i < 10; i++) {
                const angle = (i * Math.PI / 5) + (Math.PI / 2) + Math.PI;
                const radius = i % 2 === 0 ? outerRadius : innerRadius;
                const x = centerX + radius * Math.cos(angle);
                const y = centerY + radius * Math.sin(angle);
                starPoints.push(`${x},${y}`);
            }
            
            const starPath = `M${starPoints.join(' L')} Z`;
            document.getElementById('starPath').setAttribute('d', starPath);
        }

        function highlightPath(startIndex) {
            clearHighlights();
            
            const pathIndices = [];
            for (let i = 0; i < 10; i++) {
                const index = (startIndex + i * 5) % letters.length;
                pathIndices.push(index);
            }
            
            pathIndices.forEach((index, i) => {
                setTimeout(() => {
                    if (letters[index]) {
                        letters[index].classList.add('highlighted');
                        highlightedPaths.push(letters[index]);
                    }
                }, i * 100);
            });
        }

        function clearHighlights() {
            highlightedPaths.forEach(letter => {
                letter.classList.remove('highlighted');
            });
            highlightedPaths = [];
        }

        function zoomIn() {
            currentZoom = Math.min(currentZoom * 1.2, 3);
            updateZoom();
        }

        function zoomOut() {
            currentZoom = Math.max(currentZoom / 1.2, 0.3);
            updateZoom();
        }

        function resetZoom() {
            currentZoom = 1;
            updateZoom();
        }

        function updateZoom() {
            const container = document.getElementById('starContainer');
            container.style.transform = `scale(${currentZoom})`;
        }

        function animateLetters() {
            letters.forEach((letter, index) => {
                setTimeout(() => {
                    letter.style.animation = 'pulse 0.5s ease-in-out';
                    setTimeout(() => {
                        letter.style.animation = '';
                    }, 500);
                }, index * 50);
            });
        }

        // Initialize - ONLY UNITEDSTATES
        createPerfectStar();
        createUNITEDSTATESOnly();

        // Add mouse wheel zoom
        document.addEventListener('wheel', (e) => {
            e.preventDefault();
            if (e.deltaY < 0) {
                zoomIn();
            } else {
                zoomOut();
            }
        });
    </script>
</body>
</html>
