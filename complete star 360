<!DOCTYPE html>

<html lang="en">
<head>
<meta charset="utf-8"/>
<meta content="width=device-width, initial-scale=1.0" name="viewport"/>
<title>Patriotic Star - UNITEDSTATESofAMERICA250</title>
<style>
        html, body {
            margin: 0;
            padding: 0;
            background: white;
            color: black;
            font-family: 'Courier New', monospace;
            overflow: auto;
            min-height: 100vh;
            min-width: 100vw;
        }

        .container {
            width: 3500px;
            height: 3500px;
            position: absolute;
            top: 0;
            left: 0;
        }

        .star-container {
            position: absolute;
            width: 3500px;
            height: 3500px;
            transform-origin: center;
            transition: transform 0.3s ease;
            left: 0px;
            top: 0px;
        }

        .letter {
            position: absolute;
            font-size: 24px;
            font-weight: bold;
            font-family: Georgia, serif;
            user-select: none;
            text-shadow: 0 0 5px rgba(0, 0, 0, 0.3);
        }

        .letter:hover {
            transform: scale(1.1);
        }

        .letter.highlighted {
            color: #00FF00 !important;
            text-shadow: 0 0 15px rgba(0, 255, 0, 0.8) !important;
            transform: scale(1.3) !important;
        }

        .controls {
            position: fixed;
            top: 20px;
            left: 20px;
            z-index: 1000;
        }

        .control-btn {
            background: rgba(0, 0, 0, 0.1);
            border: 1px solid rgba(0, 0, 0, 0.3);
            color: black;
            padding: 10px 15px;
            margin: 5px;
            border-radius: 5px;
            cursor: pointer;
            transition: all 0.3s ease;
        }

        .control-btn:hover {
            background: rgba(0, 0, 0, 0.2);
            transform: translateY(-2px);
        }

        .info {
            position: fixed;
            bottom: 20px;
            left: 20px;
            font-size: 14px;
            opacity: 0.7;
            color: black;
        }

        .debug {
            position: fixed;
            top: 20px;
            right: 20px;
            background: rgba(0, 0, 0, 0.8);
            padding: 10px;
            border-radius: 5px;
            font-size: 12px;
            max-width: 300px;
            max-height: 400px;
            overflow-y: auto;
            color: white;
        }
    </style>
</head>
<body>
<div class="container">
<div class="star-container" id="starContainer">
<!-- Star outline SVG -->
<svg height="3500" style="position: absolute; top: 0; left: 0; pointer-events: none;" width="3500">
<polygon fill="none" id="starOutline" opacity="0.8" points="" stroke="black" stroke-width="4"></polygon>
</svg>
<!-- Letters will be positioned here by JavaScript -->
</div>
</div>
<div class="controls">
<button class="control-btn" onclick="zoomIn()">Zoom In</button>
<button class="control-btn" onclick="zoomOut()">Zoom Out</button>
<button class="control-btn" onclick="resetZoom()">Reset Zoom</button>
<button class="control-btn" onclick="highlightPath()">Highlight Path</button>
<button class="control-btn" onclick="clearHighlights()">Clear Highlights</button>
</div>
<div class="info">
<div>UNITEDSTATES: 12 rings completed</div>
<div>U(50) N(55) I(60) T(65) E(70) D(75) S(80) T(85) A(90) T(95) E(100) S(105)</div>
<div id="totalCount">Total letters will be displayed after creation</div>
<div>"Highlight Path": Shows random continuous 24-letter UNITEDSTATESofAMERICA250 sequences</div>
</div>
<div class="debug" id="debugInfo">
        Debug info will appear here...
    </div>
<script>
        let currentZoom = 1;
        let letters = [];
        let highlightedPaths = [];

        function debugLog(message) {
            console.log(message);
            const debugDiv = document.getElementById('debugInfo');
            debugDiv.innerHTML += message + '<br>';
            debugDiv.scrollTop = debugDiv.scrollHeight;
        }

        function createUNITEDSTATES() {
            debugLog("Creating UNITEDSTATES...");
            const container = document.getElementById('starContainer');
            const centerX = 1750;
            const centerY = 1750;
            const innerRadius = 220;
            const radiusStep = 35;
            
            // Pentagon vertices function
            function getPentagonVertices(radius) {
                const vertices = [];
                for (let i = 0; i < 5; i++) {
                    const angle = (i * 2 * Math.PI / 5) + (Math.PI / 2);
                    const x = centerX + radius * Math.cos(angle);
                    const y = centerY + radius * Math.sin(angle);
                    vertices.push({x, y});
                }
                return vertices;
            }

            let letterIndex = 0;
            let currentRadius = innerRadius;

            // UNITEDSTATES letter sequence with patriotic colors
            const unitedStatesSequence = [
                {letter: 'U', count: 50, color: '#0052CC'},   // Blue - UNITED
                {letter: 'N', count: 55, color: '#0052CC'},   // Blue - UNITED
                {letter: 'I', count: 60, color: '#0052CC'},   // Blue - UNITED
                {letter: 'T', count: 65, color: '#0052CC'},   // Blue - UNITED
                {letter: 'E', count: 70, color: '#0052CC'},   // Blue - UNITED
                {letter: 'D', count: 75, color: '#0052CC'},   // Blue - UNITED
                {letter: 'S', count: 80, color: '#DC143C'},   // Red - STATES
                {letter: 'T', count: 85, color: '#DC143C'},   // Red - STATES
                {letter: 'A', count: 90, color: '#DC143C'},   // Red - STATES
                {letter: 'T', count: 95, color: '#DC143C'},   // Red - STATES
                {letter: 'E', count: 100, color: '#DC143C'},  // Red - STATES
                {letter: 'S', count: 105, color: '#DC143C'}   // Red - STATES
            ];

            unitedStatesSequence.forEach((letterData, ringIndex) => {
                const vertices = getPentagonVertices(currentRadius);
                const lettersPerSide = (letterData.count + 5) / 5;
                
                // Place letters along each side
                for (let side = 0; side < 5; side++) {
                    const startVertex = vertices[side];
                    const endVertex = vertices[(side + 1) % 5];
                    
                    for (let i = 0; i < lettersPerSide; i++) {
                        const t = i / (lettersPerSide - 1);
                        const x = startVertex.x + t * (endVertex.x - startVertex.x);
                        const y = startVertex.y + t * (endVertex.y - startVertex.y);
                        
                        const letter = document.createElement('div');
                        letter.className = 'letter';
                        letter.textContent = letterData.letter;
                        letter.style.left = (x - 12) + 'px';
                        letter.style.top = (y - 12) + 'px';
                        letter.style.color = letterData.color;
                        letter.dataset.index = letterIndex;
                        letter.dataset.type = letterData.letter;
                        letter.dataset.ring = ringIndex;
                        
                        container.appendChild(letter);
                        letters.push(letter);
                        letterIndex++;
                    }
                }

                // Remove duplicate corners
                const toRemove = [];
                for (let side = 1; side < 5; side++) {
                    toRemove.push(letters.length - (5 - side) * lettersPerSide);
                }
                
                toRemove.reverse().forEach(index => {
                    if (letters[index]) {
                        letters[index].remove();
                        letters.splice(index, 1);
                        letterIndex--;
                    }
                });

                currentRadius += radiusStep;
            });

            // Update indices
            letters.forEach((letter, index) => {
                letter.dataset.index = index;
            });
            
            debugLog(`UNITEDSTATES created: ${letters.length} letters`);
        }

        function addOfAmerica250Paths() {
            debugLog("Adding ofAMERICA250 paths...");
            const container = document.getElementById('starContainer');
            const centerX = 1750;
            const centerY = 1750;
            const outerRadius = 1610;
            const innerRadius = 615;
            
            let pathLetterCount = 0;
            
            // For each of the 5 star tips
            for (let tip = 0; tip < 5; tip++) {
                const tipAngle = (tip * 2 * Math.PI / 5) + (Math.PI / 2) + Math.PI;
                const leftInnerAngle = tipAngle - (Math.PI / 5);
                const rightInnerAngle = tipAngle + (Math.PI / 5);
                
                const tipX = centerX + outerRadius * Math.cos(tipAngle);
                const tipY = centerY + outerRadius * Math.sin(tipAngle);
                
                const leftInnerX = centerX + innerRadius * Math.cos(leftInnerAngle);
                const leftInnerY = centerY + innerRadius * Math.sin(leftInnerAngle);
                const rightInnerX = centerX + innerRadius * Math.cos(rightInnerAngle);
                const rightInnerY = centerY + innerRadius * Math.sin(rightInnerAngle);
                
                // Create both paths for this tip
                pathLetterCount += createSinglePath(container, leftInnerX, leftInnerY, tipX, tipY, tip, 'left');
                pathLetterCount += createSinglePath(container, rightInnerX, rightInnerY, tipX, tipY, tip, 'right');
            }
            
            debugLog(`ofAMERICA250 paths added: ${pathLetterCount} letters`);
        }
        
        function createSinglePath(container, startX, startY, endX, endY, tipIndex, side) {
            const dirX = endX - startX;
            const dirY = endY - startY;
            const pathLength = Math.sqrt(dirX * dirX + dirY * dirY);
            const unitX = dirX / pathLength;
            const unitY = dirY / pathLength;
            
            // Offset adjustments per tip
            let offsetAdjustment = 0;
            if (tipIndex === 0) offsetAdjustment = -10;      // Top tip
            else if (tipIndex === 1) offsetAdjustment = -5;  // Upper Right tip
            else if (tipIndex === 2) offsetAdjustment = -8;  // Lower Right tip
            else if (tipIndex === 3) offsetAdjustment = -11; // Lower Left tip
            else if (tipIndex === 4) offsetAdjustment = -13; // Upper Left tip
            
            const letterSequence = [
                {char: 'o', offset: 40 + offsetAdjustment, size: 24, bold: false, color: '#0052CC'},  // Blue - of
                {char: 'f', offset: 70 + offsetAdjustment, size: 24, bold: false, color: '#0052CC'},  // Blue - of
                {char: 'A', offset: 105 + offsetAdjustment, size: 28, bold: true, color: '#DC143C'},  // Red - AMERICA
                {char: 'M', offset: 140 + offsetAdjustment, size: 28, bold: true, color: '#DC143C'},  // Red - AMERICA
                {char: 'E', offset: 175 + offsetAdjustment, size: 28, bold: true, color: '#DC143C'},  // Red - AMERICA
                {char: 'R', offset: 210 + offsetAdjustment, size: 28, bold: true, color: '#DC143C'},  // Red - AMERICA
                {char: 'I', offset: 245 + offsetAdjustment, size: 28, bold: true, color: '#DC143C'},  // Red - AMERICA
                {char: 'C', offset: 280 + offsetAdjustment, size: 28, bold: true, color: '#DC143C'},  // Red - AMERICA
                {char: 'A', offset: 315 + offsetAdjustment, size: 28, bold: true, color: '#DC143C'},  // Red - AMERICA
                {char: '2', offset: 350 + offsetAdjustment, size: 35, bold: true, color: '#FFD700'},  // Gold - 250
                {char: '5', offset: 380 + offsetAdjustment, size: 35, bold: true, color: '#FFD700'},  // Gold - 250
                {char: '0', offset: 410 + offsetAdjustment, size: 35, bold: true, color: '#FFD700'}   // Gold - 250
            ];
            
            letterSequence.forEach((letterData, index) => {
                let finalOffset = letterData.offset;
                
                // Calculate position along the path
                let x = startX + unitX * finalOffset;
                let y = startY + unitY * finalOffset;
                
                const letter = document.createElement('div');
                letter.className = 'letter';
                letter.textContent = letterData.char;
                letter.style.left = (x - letterData.size/2) + 'px';
                letter.style.top = (y - letterData.size/2) + 'px';
                letter.style.color = letterData.color;
                letter.style.fontSize = letterData.size + 'px';
                letter.style.fontWeight = letterData.bold ? 'bold' : 'normal';
                letter.dataset.index = letters.length;
                letter.dataset.tip = tipIndex;
                letter.dataset.side = side;
                letter.dataset.type = letterData.char;
                letter.dataset.pathType = 'outer';
                
                container.appendChild(letter);
                letters.push(letter);
            });
            
            return letterSequence.length;
        }

        function highlightPath() {
            debugLog("=== CREATING RANDOM CONTINUOUS PATH ===");
            clearHighlights();
            
            if (letters.length === 0) {
                debugLog("ERROR: No letters found!");
                return;
            }
            
            // Step 1: Choose a random starting U letter
            const uLetters = letters.filter(letter => letter.textContent === 'U' && letter.dataset.type === 'U');
            if (uLetters.length === 0) {
                debugLog("ERROR: No U letters found!");
                return;
            }
            
            const startU = uLetters[Math.floor(Math.random() * uLetters.length)];
            debugLog(`Starting random path from U at index ${startU.dataset.index}`);
            
            // Step 2: Build continuous path through UNITEDSTATES
            const unitedStatesPath = buildContinuousUnitedStatesPath(startU);
            
            // Step 3: Find closest tip and continue with ofAMERICA250
            const lastUnitedStatesLetter = unitedStatesPath[unitedStatesPath.length - 1];
            const ofAmericaPath = buildContinuousOfAmericaPath(lastUnitedStatesLetter);
            
            // Step 4: Combine and highlight the complete path
            const completePath = [...unitedStatesPath, ...ofAmericaPath];
            
            debugLog(`Complete random path: ${completePath.length} letters`);
            
            // Highlight with animation
            completePath.forEach((letter, index) => {
                setTimeout(() => {
                    letter.classList.add('highlighted');
                    highlightedPaths.push(letter);
                    debugLog(`✓ Step ${index + 1}: "${letter.textContent}" at index ${letter.dataset.index}`);
                    
                    if (index === completePath.length - 1) {
                        debugLog("=== RANDOM PATH COMPLETE ===");
                        debugLog(`Final sequence: ${highlightedPaths.map(l => l.textContent).join('')}`);
                    }
                }, index * 80);
            });
        }
        
        function buildContinuousUnitedStatesPath(startU) {
            debugLog("Building continuous UNITEDSTATES path...");
            
            const path = [startU];
            let currentLetter = startU;
            const usedLetters = new Set([startU.dataset.index]);
            
            // UNITEDSTATES sequence after U - with ring information
            const sequence = [
                {char: 'N', ring: 1}, {char: 'I', ring: 2}, {char: 'T', ring: 3}, 
                {char: 'E', ring: 4}, {char: 'D', ring: 5}, {char: 'S', ring: 6}, 
                {char: 'T', ring: 7}, {char: 'A', ring: 8}, {char: 'T', ring: 9}, 
                {char: 'E', ring: 10}, {char: 'S', ring: 11}
            ];
            
            sequence.forEach((targetInfo, seqIndex) => {
                const targetChar = targetInfo.char;
                const targetRing = targetInfo.ring;
                
                debugLog(`Looking for ${targetChar} in ring ${targetRing}...`);
                
                // Find all letters of this type in the correct ring that haven't been used
                const candidateLetters = letters.filter(letter => 
                    letter.textContent === targetChar && 
                    letter.dataset.type === targetChar &&
                    parseInt(letter.dataset.ring) === targetRing &&
                    !usedLetters.has(letter.dataset.index)
                );
                
                debugLog(`Found ${candidateLetters.length} unused ${targetChar} letters in ring ${targetRing}`);
                
                if (candidateLetters.length === 0) {
                    debugLog(`ERROR: No unused ${targetChar} letters found in ring ${targetRing}!`);
                    return;
                }
                
                // Find the closest letter to current position (with some randomness for diversity)
                const currentX = parseFloat(currentLetter.style.left) + 12;
                const currentY = parseFloat(currentLetter.style.top) + 12;
                
                let closestLetter = null;
                let minDistance = Infinity;
                
                candidateLetters.forEach(candidate => {
                    const candidateX = parseFloat(candidate.style.left) + 12;
                    const candidateY = parseFloat(candidate.style.top) + 12;
                    
                    const distance = Math.sqrt(
                        (candidateX - currentX) ** 2 + 
                        (candidateY - currentY) ** 2
                    );
                    
                    // Add some randomness for diversity while maintaining continuity
                    if (distance < minDistance || (distance < minDistance * 1.3 && Math.random() < 0.4)) {
                        minDistance = distance;
                        closestLetter = candidate;
                    }
                });
                
                if (closestLetter) {
                    path.push(closestLetter);
                    currentLetter = closestLetter;
                    usedLetters.add(closestLetter.dataset.index);
                    debugLog(`✓ Selected ${targetChar} (ring ${targetRing}) at index ${closestLetter.dataset.index}, distance ${minDistance.toFixed(1)}`);
                } else {
                    debugLog(`ERROR: Could not select ${targetChar} from ring ${targetRing}!`);
                }
            });
            
            debugLog(`UNITEDSTATES path built: ${path.length} letters`);
            debugLog(`Path sequence: ${path.map(l => l.textContent).join('')}`);
            return path;
        }
        
        function buildContinuousOfAmericaPath(lastUnitedStatesLetter) {
            debugLog("Building continuous ofAMERICA250 path...");
            
            const lastX = parseFloat(lastUnitedStatesLetter.style.left) + 12;
            const lastY = parseFloat(lastUnitedStatesLetter.style.top) + 12;
            
            // Find ALL ofAMERICA250 letters (both outer paths and fill-in letters)
            const allOfAmericaLetters = letters.filter(letter => 
                letter.dataset.pathType === 'outer' || letter.dataset.pathType === 'fill'
            );
            
            if (allOfAmericaLetters.length === 0) {
                debugLog("ERROR: No ofAMERICA250 letters found!");
                return [];
            }
            
            debugLog(`Found ${allOfAmericaLetters.length} total ofAMERICA250 letters (outer + fill-in)`);
            
            // Find the closest 'o' letter to start the ofAMERICA250 sequence
            const oLetters = allOfAmericaLetters.filter(letter => 
                letter.textContent === 'o' && (letter.dataset.type === 'o' || letter.dataset.type === 'fill-o')
            );
            
            if (oLetters.length === 0) {
                debugLog("ERROR: No 'o' letters found!");
                return [];
            }
            
            // Find closest 'o' to the last UNITEDSTATES letter (with some randomness)
            let closestO = null;
            let minDistance = Infinity;
            
            oLetters.forEach(oLetter => {
                const oX = parseFloat(oLetter.style.left) + 12;
                const oY = parseFloat(oLetter.style.top) + 12;
                
                const distance = Math.sqrt((oX - lastX) ** 2 + (oY - lastY) ** 2);
                
                // Add randomness for diversity
                if (distance < minDistance || (distance < minDistance * 1.5 && Math.random() < 0.3)) {
                    minDistance = distance;
                    closestO = oLetter;
                }
            });
            
            if (!closestO) {
                debugLog("ERROR: Could not find closest 'o'!");
                return [];
            }
            
            debugLog(`Starting ofAMERICA250 from 'o' at distance ${minDistance.toFixed(1)} from last S`);
            
            // Build continuous path through ofAMERICA250 sequence
            const path = [closestO];
            let currentLetter = closestO;
            
            // ofAMERICA250 sequence after 'o'
            const sequence = ['f', 'A', 'M', 'E', 'R', 'I', 'C', 'A', '2', '5', '0'];
            
            sequence.forEach((targetChar, seqIndex) => {
                // Find all letters of this type (both outer and fill-in)
                const candidateLetters = allOfAmericaLetters.filter(letter => 
                    letter.textContent === targetChar && 
                    (letter.dataset.type === targetChar || letter.dataset.type === `fill-${targetChar}`)
                );
                
                if (candidateLetters.length === 0) {
                    debugLog(`ERROR: No ${targetChar} letters found in ofAMERICA250!`);
                    return;
                }
                
                // Find the closest letter to current position (with randomness for diversity)
                const currentX = parseFloat(currentLetter.style.left) + 12;
                const currentY = parseFloat(currentLetter.style.top) + 12;
                
                let closestLetter = null;
                let minDistance = Infinity;
                
                candidateLetters.forEach(candidate => {
                    const candidateX = parseFloat(candidate.style.left) + 12;
                    const candidateY = parseFloat(candidate.style.top) + 12;
                    
                    const distance = Math.sqrt(
                        (candidateX - currentX) ** 2 + 
                        (candidateY - currentY) ** 2
                    );
                    
                    // Add randomness for diversity while maintaining continuity
                    if (distance < minDistance || (distance < minDistance * 1.4 && Math.random() < 0.35)) {
                        minDistance = distance;
                        closestLetter = candidate;
                    }
                });
                
                if (closestLetter) {
                    path.push(closestLetter);
                    currentLetter = closestLetter;
                    const letterType = closestLetter.dataset.pathType === 'fill' ? 'fill-in' : 'outer';
                    debugLog(`${targetChar} (${letterType}): distance ${minDistance.toFixed(1)} from previous letter`);
                } else {
                    debugLog(`ERROR: Could not find adjacent ${targetChar} in ofAMERICA250!`);
                }
            });
            
            debugLog(`ofAMERICA250 path built: ${path.length} letters (mix of outer and fill-in)`);
            return path;
        }

        function clearHighlights() {
            highlightedPaths.forEach(letter => {
                letter.classList.remove('highlighted');
            });
            highlightedPaths = [];
        }

        function zoomIn() {
            currentZoom = Math.min(currentZoom * 1.2, 3);
            updateZoom();
        }

        function zoomOut() {
            currentZoom = Math.max(currentZoom / 1.2, 0.3);
            updateZoom();
        }

        function resetZoom() {
            currentZoom = 1;
            updateZoom();
        }

        function updateZoom() {
            const container = document.getElementById('starContainer');
            container.style.transform = `scale(${currentZoom})`;
        }

        function createStarOutline() {
            debugLog("Creating star outline...");
            const centerX = 1750;
            const centerY = 1750;
            const outerRadius = 1610;
            const innerRadius = 615;
            
            let points = [];
            
            // Create star points (alternating outer and inner)
            for (let i = 0; i < 10; i++) {
                const angle = (i * Math.PI / 5) + (Math.PI / 2) + Math.PI;
                const radius = (i % 2 === 0) ? outerRadius : innerRadius;
                const x = centerX + radius * Math.cos(angle);
                const y = centerY + radius * Math.sin(angle);
                points.push(`${x.toFixed(0)},${y.toFixed(0)}`);
            }
            
            const starOutline = document.getElementById('starOutline');
            starOutline.setAttribute('points', points.join(' '));
            debugLog("Star outline created");
        }

        function addFillInLetters() {
            debugLog("Adding fill-in letters...");
            const container = document.getElementById('starContainer');
            const centerX = 1750;
            const centerY = 1750;
            const outerRadius = 1610;
            const innerRadius = 615;
            
            let fillInCount = 0;
            
            // Function to add fill-in letters for a specific tip
            function addTipFillIn(tipIndex) {
                const tipAngle = (tipIndex * 2 * Math.PI / 5) + (Math.PI / 2) + Math.PI;
                const leftInnerAngle = tipAngle - (Math.PI / 5);
                const rightInnerAngle = tipAngle + (Math.PI / 5);
                
                const tipX = centerX + outerRadius * Math.cos(tipAngle);
                const tipY = centerY + outerRadius * Math.sin(tipAngle);
                
                const leftInnerX = centerX + innerRadius * Math.cos(leftInnerAngle);
                const leftInnerY = centerY + innerRadius * Math.sin(leftInnerAngle);
                const rightInnerX = centerX + innerRadius * Math.cos(rightInnerAngle);
                const rightInnerY = centerY + innerRadius * Math.sin(rightInnerAngle);
                
                // Offset adjustments per tip
                let offsetAdjustment = 0;
                if (tipIndex === 0) offsetAdjustment = -10;
                else if (tipIndex === 1) offsetAdjustment = -5;
                else if (tipIndex === 2) offsetAdjustment = -8;
                else if (tipIndex === 3) offsetAdjustment = -11;
                else if (tipIndex === 4) offsetAdjustment = -13;
                
                // Calculate unit vectors for both paths
                const leftDirX = tipX - leftInnerX;
                const leftDirY = tipY - leftInnerY;
                const leftPathLength = Math.sqrt(leftDirX * leftDirX + leftDirY * leftDirY);
                const leftUnitX = leftDirX / leftPathLength;
                const leftUnitY = leftDirY / leftPathLength;
                
                const rightDirX = tipX - rightInnerX;
                const rightDirY = tipY - rightInnerY;
                const rightPathLength = Math.sqrt(rightDirX * rightDirX + rightDirY * rightDirY);
                const rightUnitX = rightDirX / rightPathLength;
                const rightUnitY = rightDirY / rightPathLength;
                
                // Letter sequence with counts and patriotic colors
                const letterSequence = [
                    {char: 'o', count: 19, offset: 40, size: 24, bold: false, color: '#0052CC'},  // Blue - of
                    {char: 'f', count: 18, offset: 70, size: 24, bold: false, color: '#0052CC'},  // Blue - of
                    {char: 'A', count: 17, offset: 105, size: 28, bold: true, color: '#DC143C'},  // Red - AMERICA
                    {char: 'M', count: 16, offset: 140, size: 28, bold: true, color: '#DC143C'},  // Red - AMERICA
                    {char: 'E', count: 15, offset: 175, size: 28, bold: true, color: '#DC143C'},  // Red - AMERICA
                    {char: 'R', count: 14, offset: 210, size: 28, bold: true, color: '#DC143C'},  // Red - AMERICA
                    {char: 'I', count: 13, offset: 245, size: 28, bold: true, color: '#DC143C'},  // Red - AMERICA
                    {char: 'C', count: 12, offset: 280, size: 28, bold: true, color: '#DC143C'},  // Red - AMERICA
                    {char: 'A', count: 11, offset: 315, size: 28, bold: true, color: '#DC143C'},  // Red - AMERICA
                    {char: '2', count: 10, offset: 350, size: 35, bold: true, color: '#FFD700'},  // Gold - 250
                    {char: '5', count: 9, offset: 380, size: 35, bold: true, color: '#FFD700'},   // Gold - 250
                    {char: '0', count: 8, offset: 410, size: 35, bold: true, color: '#FFD700'}    // Gold - 250
                ];
                
                letterSequence.forEach(letterData => {
                    // Calculate left path position
                    const leftLetterOffset = letterData.offset + offsetAdjustment;
                    let leftLetterX = leftInnerX + leftUnitX * leftLetterOffset;
                    let leftLetterY = leftInnerY + leftUnitY * leftLetterOffset;
                    
                    // Calculate right path position
                    const rightLetterOffset = letterData.offset + offsetAdjustment;
                    let rightLetterX = rightInnerX + rightUnitX * rightLetterOffset;
                    let rightLetterY = rightInnerY + rightUnitY * rightLetterOffset;
                    
                    // Create fill-in letters equally spaced between the exact outer positions
                    for (let i = 1; i <= letterData.count; i++) {
                        const t = i / (letterData.count + 1);
                        
                        const x = leftLetterX + t * (rightLetterX - leftLetterX);
                        const y = leftLetterY + t * (rightLetterY - leftLetterY);
                        
                        const letter = document.createElement('div');
                        letter.className = 'letter';
                        letter.textContent = letterData.char;
                        letter.style.left = (x - letterData.size/2) + 'px';
                        letter.style.top = (y - letterData.size/2) + 'px';
                        letter.style.color = letterData.color;
                        letter.style.fontSize = letterData.size + 'px';
                        letter.style.fontWeight = letterData.bold ? 'bold' : 'normal';
                        letter.dataset.index = letters.length;
                        letter.dataset.type = 'fill-' + letterData.char;
                        letter.dataset.tip = tipIndex;
                        letter.dataset.pathType = 'fill';
                        
                        container.appendChild(letter);
                        letters.push(letter);
                        fillInCount++;
                    }
                });
            }
            
            // Add fill-in letters for all tips
            addTipFillIn(0); // Top tip
            addTipFillIn(1); // Upper right tip
            addTipFillIn(2); // Lower right tip
            addTipFillIn(3); // Lower left tip
            addTipFillIn(4); // Upper left tip
            
            debugLog(`Fill-in letters added: ${fillInCount} letters`);
        }

        // Initialize everything when page loads
        window.addEventListener('DOMContentLoaded', function() {
            debugLog("=== STARTING INITIALIZATION ===");
            createUNITEDSTATES();
            addOfAmerica250Paths();
            addFillInLetters();
            createStarOutline();
            
            // Update info display
            document.getElementById('totalCount').textContent = `Total: ${letters.length} letters`;
            
            debugLog(`=== INITIALIZATION COMPLETE: ${letters.length} total letters ===`);
        });

        // Add mouse wheel zoom
        document.addEventListener('wheel', (e) => {
            e.preventDefault();
            if (e.deltaY < 0) {
                zoomIn();
            } else {
                zoomOut();
            }
        });
    </script>
</body>
</html>
