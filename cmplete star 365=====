<!DOCTYPE html>

<html lang="en">
<head>
<meta charset="utf-8"/>
<meta content="width=device-width, initial-scale=1.0" name="viewport"/>
<title>Patriotic Star - UNITEDSTATESofAMERICA250</title>
<style>
        html, body {
            margin: 0;
            padding: 0;
            background: white;
            color: black;
            font-family: 'Courier New', monospace;
            overflow: auto;
            min-height: 100vh;
            min-width: 100vw;
        }

        .container {
            width: 3500px;
            height: 3500px;
            position: absolute;
            top: 0;
            left: 0;
        }

        .star-container {
            position: absolute;
            width: 3500px;
            height: 3500px;
            transform-origin: center;
            transition: transform 0.3s ease;
            left: 0px;
            top: 0px;
        }

        .letter {
            position: absolute;
            font-size: 24px;
            font-weight: bold;
            font-family: Georgia, serif;
            user-select: none;
            text-shadow: 0 0 5px rgba(0, 0, 0, 0.3);
        }

        /* Beautiful permanent effects for special positions */
        .letter.corner-letter {
            background: linear-gradient(135deg, rgba(255, 215, 0, 0.2), rgba(255, 215, 0, 0.1)) !important;
            border: 2px solid rgba(255, 215, 0, 0.4) !important;
            border-radius: 8px !important;
            padding: 3px 6px !important;
            text-shadow: 0 0 8px rgba(255, 215, 0, 0.8), 0 0 15px rgba(255, 215, 0, 0.4) !important;
            transform: scale(1.05) !important;
            font-weight: 900 !important;
            box-shadow: 0 0 12px rgba(255, 215, 0, 0.3) !important;
        }

        .letter.outline-letter {
            background: linear-gradient(135deg, rgba(0, 100, 255, 0.15), rgba(0, 100, 255, 0.08)) !important;
            border: 2px solid rgba(0, 100, 255, 0.5) !important;
            border-radius: 6px !important;
            padding: 2px 5px !important;
            text-shadow: 0 0 10px rgba(0, 100, 255, 0.9), 0 0 20px rgba(0, 100, 255, 0.5) !important;
            transform: scale(1.08) !important;
            box-shadow: 0 0 15px rgba(0, 100, 255, 0.4) !important;
        }

        .letter.edge-letter {
            background: linear-gradient(135deg, rgba(255, 100, 150, 0.12), rgba(255, 100, 150, 0.06)) !important;
            border: 1px solid rgba(255, 100, 150, 0.4) !important;
            border-radius: 5px !important;
            padding: 2px 4px !important;
            text-shadow: 0 0 6px rgba(255, 100, 150, 0.7), 0 0 12px rgba(255, 100, 150, 0.3) !important;
            transform: scale(1.03) !important;
            font-style: italic !important;
            box-shadow: 0 0 8px rgba(255, 100, 150, 0.2) !important;
        }

        .letter:hover {
            transform: scale(1.1);
        }

        .letter.highlighted {
            color: #00FF00 !important;
            text-shadow: 0 0 15px rgba(0, 255, 0, 0.8) !important;
            transform: scale(1.3) !important;
            font-weight: bold !important;
            font-size: inherit !important;
            background: none !important;
            border: none !important;
            outline: none !important;
            opacity: 1 !important;
        }

        .controls {
            position: fixed;
            top: 20px;
            left: 20px;
            z-index: 1000;
        }

        .control-btn {
            background: rgba(0, 0, 0, 0.1);
            border: 1px solid rgba(0, 0, 0, 0.3);
            color: black;
            padding: 10px 15px;
            margin: 5px;
            border-radius: 5px;
            cursor: pointer;
            transition: all 0.3s ease;
        }

        .control-btn:hover {
            background: rgba(0, 0, 0, 0.2);
            transform: translateY(-2px);
        }

        .info {
            position: fixed;
            bottom: 20px;
            left: 20px;
            font-size: 14px;
            opacity: 0.7;
            color: black;
        }

        .debug {
            position: fixed;
            top: 20px;
            right: 20px;
            background: rgba(0, 0, 0, 0.8);
            padding: 10px;
            border-radius: 5px;
            font-size: 12px;
            max-width: 300px;
            max-height: 400px;
            overflow-y: auto;
            color: white;
        }
    </style>
</head>
<body>
<div class="container">
<div class="star-container" id="starContainer">
<!-- Star outline SVG -->
<svg height="3500" style="position: absolute; top: 0; left: 0; pointer-events: none;" width="3500">
<polygon fill="none" id="starOutline" opacity="0.8" points="" stroke="black" stroke-width="4"></polygon>
</svg>
<!-- Letters will be positioned here by JavaScript -->
</div>
</div>
<div class="controls">
<button class="control-btn" onclick="zoomIn()">Zoom In</button>
<button class="control-btn" onclick="zoomOut()">Zoom Out</button>
<button class="control-btn" onclick="resetZoom()">Reset Zoom</button>
<button class="control-btn" onclick="highlightPath()">Highlight Path</button>
<button class="control-btn" onclick="clearHighlights()">Clear Highlights</button>
</div>
<div class="info">
<div>UNITEDSTATES: 12 rings completed</div>
<div>U(50) N(55) I(60) T(65) E(70) D(75) S(80) T(85) A(90) T(95) E(100) S(105)</div>
<div id="totalCount">Total letters will be displayed after creation</div>
<div>"Highlight Path": Shows random continuous 24-letter UNITEDSTATESofAMERICA250 sequences</div>
</div>
<div class="debug" id="debugInfo">
        Debug info will appear here...
    </div>
<script>
        let currentZoom = 1;
        let letters = [];
        let highlightedPaths = [];

        function debugLog(message) {
            console.log(message);
            const debugDiv = document.getElementById('debugInfo');
            debugDiv.innerHTML += message + '<br>';
            debugDiv.scrollTop = debugDiv.scrollHeight;
        }

        function createUNITEDSTATES() {
            debugLog("Creating UNITEDSTATES...");
            const container = document.getElementById('starContainer');
            const centerX = 1750;
            const centerY = 1750;
            const innerRadius = 220;
            const radiusStep = 35;
            
            // Pentagon vertices function
            function getPentagonVertices(radius) {
                const vertices = [];
                for (let i = 0; i < 5; i++) {
                    const angle = (i * 2 * Math.PI / 5) + (Math.PI / 2);
                    const x = centerX + radius * Math.cos(angle);
                    const y = centerY + radius * Math.sin(angle);
                    vertices.push({x, y});
                }
                return vertices;
            }

            let letterIndex = 0;
            let currentRadius = innerRadius;

            // UNITEDSTATES letter sequence with patriotic colors
            const unitedStatesSequence = [
                {letter: 'U', count: 50, color: '#0052CC'},   // Blue - UNITED
                {letter: 'N', count: 55, color: '#0052CC'},   // Blue - UNITED
                {letter: 'I', count: 60, color: '#0052CC'},   // Blue - UNITED
                {letter: 'T', count: 65, color: '#0052CC'},   // Blue - UNITED
                {letter: 'E', count: 70, color: '#0052CC'},   // Blue - UNITED
                {letter: 'D', count: 75, color: '#0052CC'},   // Blue - UNITED
                {letter: 'S', count: 80, color: '#DC143C'},   // Red - STATES
                {letter: 'T', count: 85, color: '#DC143C'},   // Red - STATES
                {letter: 'A', count: 90, color: '#DC143C'},   // Red - STATES
                {letter: 'T', count: 95, color: '#DC143C'},   // Red - STATES
                {letter: 'E', count: 100, color: '#DC143C'},  // Red - STATES
                {letter: 'S', count: 105, color: '#DC143C'}   // Red - STATES
            ];

            unitedStatesSequence.forEach((letterData, ringIndex) => {
                const vertices = getPentagonVertices(currentRadius);
                const lettersPerSide = (letterData.count + 5) / 5;
                
                // Place letters along each side
                for (let side = 0; side < 5; side++) {
                    const startVertex = vertices[side];
                    const endVertex = vertices[(side + 1) % 5];
                    
                    for (let i = 0; i < lettersPerSide; i++) {
                        const t = i / (lettersPerSide - 1);
                        const x = startVertex.x + t * (endVertex.x - startVertex.x);
                        const y = startVertex.y + t * (endVertex.y - startVertex.y);
                        
                        const letter = document.createElement('div');
                        letter.className = 'letter';
                        letter.textContent = letterData.letter;
                        letter.style.left = (x - 12) + 'px';
                        letter.style.top = (y - 12) + 'px';
                        letter.style.color = letterData.color;
                        letter.dataset.index = letterIndex;
                        letter.dataset.type = letterData.letter;
                        letter.dataset.ring = ringIndex;
                        
                        // Add special visual effects for pentagon corner letters
                        if (i === 0 || i === lettersPerSide - 1) {
                            letter.classList.add('corner-letter');
                        }
                        
                        container.appendChild(letter);
                        letters.push(letter);
                        letterIndex++;
                    }
                }

                // Remove duplicate corners
                const toRemove = [];
                for (let side = 1; side < 5; side++) {
                    toRemove.push(letters.length - (5 - side) * lettersPerSide);
                }
                
                toRemove.reverse().forEach(index => {
                    if (letters[index]) {
                        letters[index].remove();
                        letters.splice(index, 1);
                        letterIndex--;
                    }
                });

                currentRadius += radiusStep;
            });

            // Update indices
            letters.forEach((letter, index) => {
                letter.dataset.index = index;
            });
            
            debugLog(`UNITEDSTATES created: ${letters.length} letters`);
        }

        function addOfAmerica250Paths() {
            debugLog("Adding ofAMERICA250 paths...");
            const container = document.getElementById('starContainer');
            const centerX = 1750;
            const centerY = 1750;
            const outerRadius = 1610;
            const innerRadius = 615;
            
            let pathLetterCount = 0;
            
            // For each of the 5 star tips
            for (let tip = 0; tip < 5; tip++) {
                const tipAngle = (tip * 2 * Math.PI / 5) + (Math.PI / 2) + Math.PI;
                const leftInnerAngle = tipAngle - (Math.PI / 5);
                const rightInnerAngle = tipAngle + (Math.PI / 5);
                
                const tipX = centerX + outerRadius * Math.cos(tipAngle);
                const tipY = centerY + outerRadius * Math.sin(tipAngle);
                
                const leftInnerX = centerX + innerRadius * Math.cos(leftInnerAngle);
                const leftInnerY = centerY + innerRadius * Math.sin(leftInnerAngle);
                const rightInnerX = centerX + innerRadius * Math.cos(rightInnerAngle);
                const rightInnerY = centerY + innerRadius * Math.sin(rightInnerAngle);
                
                // Create both paths for this tip
                pathLetterCount += createSinglePath(container, leftInnerX, leftInnerY, tipX, tipY, tip, 'left');
                pathLetterCount += createSinglePath(container, rightInnerX, rightInnerY, tipX, tipY, tip, 'right');
            }
            
            debugLog(`ofAMERICA250 paths added: ${pathLetterCount} letters`);
        }
        
        function createSinglePath(container, startX, startY, endX, endY, tipIndex, side) {
            const dirX = endX - startX;
            const dirY = endY - startY;
            const pathLength = Math.sqrt(dirX * dirX + dirY * dirY);
            const unitX = dirX / pathLength;
            const unitY = dirY / pathLength;
            
            // Offset adjustments per tip
            let offsetAdjustment = 0;
            if (tipIndex === 0) offsetAdjustment = -10;      // Top tip
            else if (tipIndex === 1) offsetAdjustment = -5;  // Upper Right tip
            else if (tipIndex === 2) offsetAdjustment = -8;  // Lower Right tip
            else if (tipIndex === 3) offsetAdjustment = -11; // Lower Left tip
            else if (tipIndex === 4) offsetAdjustment = -13; // Upper Left tip
            
            const letterSequence = [
                {char: 'o', offset: 40 + offsetAdjustment, size: 24, bold: false, color: '#0052CC'},  // Blue - of
                {char: 'f', offset: 70 + offsetAdjustment, size: 24, bold: false, color: '#0052CC'},  // Blue - of
                {char: 'A', offset: 105 + offsetAdjustment, size: 28, bold: true, color: '#DC143C'},  // Red - AMERICA
                {char: 'M', offset: 140 + offsetAdjustment, size: 28, bold: true, color: '#DC143C'},  // Red - AMERICA
                {char: 'E', offset: 175 + offsetAdjustment, size: 28, bold: true, color: '#DC143C'},  // Red - AMERICA
                {char: 'R', offset: 210 + offsetAdjustment, size: 28, bold: true, color: '#DC143C'},  // Red - AMERICA
                {char: 'I', offset: 245 + offsetAdjustment, size: 28, bold: true, color: '#DC143C'},  // Red - AMERICA
                {char: 'C', offset: 280 + offsetAdjustment, size: 28, bold: true, color: '#DC143C'},  // Red - AMERICA
                {char: 'A', offset: 315 + offsetAdjustment, size: 28, bold: true, color: '#DC143C'},  // Red - AMERICA
                {char: '2', offset: 350 + offsetAdjustment, size: 35, bold: true, color: '#FFD700'},  // Gold - 250
                {char: '5', offset: 380 + offsetAdjustment, size: 35, bold: true, color: '#FFD700'},  // Gold - 250
                {char: '0', offset: 410 + offsetAdjustment, size: 35, bold: true, color: '#FFD700'}   // Gold - 250
            ];
            
            // Special adjustments for specific paths (your precise calibrations)
            const isPath1 = (tipIndex === 0 && side === 'left');
            const isPath2 = (tipIndex === 0 && side === 'right');
            const isPath3 = (tipIndex === 1 && side === 'left');
            const isPath4 = (tipIndex === 1 && side === 'right');
            const isPath5 = (tipIndex === 2 && side === 'left');
            const isPath6 = (tipIndex === 2 && side === 'right');
            const isPath7 = (tipIndex === 3 && side === 'left');
            const isPath8 = (tipIndex === 3 && side === 'right');
            const isPath9 = (tipIndex === 4 && side === 'left');
            const isPath10 = (tipIndex === 4 && side === 'right');
            
            letterSequence.forEach((letterData, index) => {
                let finalOffset = letterData.offset;
                
                // Move paths 7 and 8 closer to "S" letters (your adjustment)
                if (isPath7 || isPath8) {
                    finalOffset -= 4; // Move 4px closer to "S" (2px more)
                }
                
                // Move paths 9 and 10 closer to "S" letters (your adjustment)
                if (isPath9 || isPath10) {
                    finalOffset -= 3; // Move 3px closer to "S"
                }
                
                // Calculate position along the path
                let x = startX + unitX * finalOffset;
                let y = startY + unitY * finalOffset;
                
                // Perpendicular adjustments for various paths (your precise positioning)
                const perpX = -unitY;
                const perpY = unitX;
                
                // Move entire paths toward center of tip width (your calibrated adjustments)
                if (isPath1 || isPath2 || isPath3 || isPath4 || isPath5 || isPath6 || isPath7 || isPath8 || isPath9 || isPath10) {
                    let perpOffset;
                    if (isPath1) {
                        // Path 1: move inward (toward center of tip width)
                        perpOffset = 17; // Move 17px inward (your calibrated value)
                    } else if (isPath2) {
                        // Path 2: move inward (toward center of tip width)
                        perpOffset = -8; // Move 8px inward (your calibrated value)
                    } else if (isPath3) {
                        // Path 3: move entire path inward (toward center of tip width)
                        perpOffset = 9; // Move 9px inward (your calibrated value)
                    } else if (isPath4) {
                        // Path 4: move entire path inward (toward center of tip width)
                        perpOffset = -11; // Move 11px inward (your calibrated value)
                    } else if (isPath5) {
                        // Path 5: move entire path inward (toward center of tip width)
                        perpOffset = 6; // Move 6px inward (your calibrated value)
                    } else if (isPath6) {
                        // Path 6: move entire path inward (toward center of tip width)
                        perpOffset = -14; // Move 14px inward (your calibrated value)
                    } else if (isPath7) {
                        // Path 7: move entire path inward (toward center of tip width)
                        perpOffset = 10; // Move 10px inward (your calibrated value)
                    } else if (isPath8) {
                        // Path 8: move entire path inward (toward center of tip width)
                        perpOffset = -14; // Move 14px inward (your calibrated value)
                    } else if (isPath9) {
                        // Path 9: move entire path inward (toward center of tip width)
                        perpOffset = 18; // Move 18px inward (your calibrated value)
                    } else if (isPath10) {
                        // Path 10: move entire path inward (toward center of tip width)
                        perpOffset = -9; // Move 9px inward (your calibrated value)
                    }
                    
                    x += perpX * perpOffset;
                    y += perpY * perpOffset;
                }
                
                // Move "250" perpendicular to tip direction in paths 3 and 10 for alignment (your precise adjustment)
                if ((isPath3 || isPath10) && (letterData.char === '2' || letterData.char === '5' || letterData.char === '0')) {
                    let perpOffset;
                    if (isPath3) {
                        // Path 3: move outward (away from center of tip width toward outer edge)
                        perpOffset = -4; // Move 4px outward (your calibrated value for perfect alignment)
                    } else if (isPath10) {
                        // Path 10: keep current position (your calibrated value)
                        perpOffset = 2; // Move 2px outward (your calibrated value)
                    }
                    
                    x += perpX * perpOffset;
                    y += perpY * perpOffset;
                }
                
                const letter = document.createElement('div');
                letter.className = 'letter outline-letter'; // Add outline-letter class for star-outline paths
                letter.textContent = letterData.char;
                letter.style.left = (x - letterData.size/2) + 'px';
                letter.style.top = (y - letterData.size/2) + 'px';
                letter.style.color = letterData.color;
                letter.style.fontSize = letterData.size + 'px';
                letter.style.fontWeight = letterData.bold ? 'bold' : 'normal';
                letter.dataset.index = letters.length;
                letter.dataset.tip = tipIndex;
                letter.dataset.side = side;
                letter.dataset.type = letterData.char;
                letter.dataset.pathType = 'outer';
                
                container.appendChild(letter);
                letters.push(letter);
            });
            
            return letterSequence.length;
        }

        function highlightPath() {
            debugLog("=== CREATING TRULY CONTINUOUS PATH ===");
            clearHighlights();
            
            if (letters.length === 0) {
                debugLog("ERROR: No letters found!");
                return;
            }
            
            // Step 1: Choose a random starting U letter
            const uLetters = letters.filter(letter => letter.textContent === 'U' && letter.dataset.type === 'U');
            if (uLetters.length === 0) {
                debugLog("ERROR: No U letters found!");
                return;
            }
            
            const startU = uLetters[Math.floor(Math.random() * uLetters.length)];
            debugLog(`Starting continuous path from U at index ${startU.dataset.index}`);
            
            // Step 2: Build ONE continuous path through all 24 letters
            const completePath = buildTrulyContinuousPath(startU);
            
            debugLog(`Complete continuous path: ${completePath.length} letters`);
            
            // Highlight with animation
            completePath.forEach((letter, index) => {
                setTimeout(() => {
                    letter.classList.add('highlighted');
                    highlightedPaths.push(letter);
                    debugLog(`✓ Step ${index + 1}: "${letter.textContent}" at index ${letter.dataset.index}`);
                    
                    if (index === completePath.length - 1) {
                        debugLog("=== CONTINUOUS PATH COMPLETE ===");
                        debugLog(`Final sequence: ${highlightedPaths.map(l => l.textContent).join('')}`);
                    }
                }, index * 80);
            });
        }
        
        function buildTrulyContinuousPath(startU) {
            debugLog("Building truly continuous 24-letter path...");
            
            const path = [startU];
            let currentLetter = startU;
            const usedLetters = new Set([startU.dataset.index]);
            
            // Complete 24-letter sequence with word boundaries: UNITEDSTATESofAMERICA250
            const fullSequence = [
                // UNITEDSTATES (with ring info for pentagon letters)
                {char: 'N', ring: 1, section: 'UNITEDSTATES', word: 'UNITED'}, 
                {char: 'I', ring: 2, section: 'UNITEDSTATES', word: 'UNITED'}, 
                {char: 'T', ring: 3, section: 'UNITEDSTATES', word: 'UNITED'}, 
                {char: 'E', ring: 4, section: 'UNITEDSTATES', word: 'UNITED'}, 
                {char: 'D', ring: 5, section: 'UNITEDSTATES', word: 'UNITED'}, 
                {char: 'S', ring: 6, section: 'UNITEDSTATES', word: 'STATES'}, 
                {char: 'T', ring: 7, section: 'UNITEDSTATES', word: 'STATES'}, 
                {char: 'A', ring: 8, section: 'UNITEDSTATES', word: 'STATES'}, 
                {char: 'T', ring: 9, section: 'UNITEDSTATES', word: 'STATES'}, 
                {char: 'E', ring: 10, section: 'UNITEDSTATES', word: 'STATES'}, 
                {char: 'S', ring: 11, section: 'UNITEDSTATES', word: 'STATES'},
                // ofAMERICA250 (no ring info, from tips)
                {char: 'o', ring: null, section: 'ofAMERICA250', word: 'of'},
                {char: 'f', ring: null, section: 'ofAMERICA250', word: 'of'},
                {char: 'A', ring: null, section: 'ofAMERICA250', word: 'AMERICA'},
                {char: 'M', ring: null, section: 'ofAMERICA250', word: 'AMERICA'},
                {char: 'E', ring: null, section: 'ofAMERICA250', word: 'AMERICA'},
                {char: 'R', ring: null, section: 'ofAMERICA250', word: 'AMERICA'},
                {char: 'I', ring: null, section: 'ofAMERICA250', word: 'AMERICA'},
                {char: 'C', ring: null, section: 'ofAMERICA250', word: 'AMERICA'},
                {char: 'A', ring: null, section: 'ofAMERICA250', word: 'AMERICA'},
                {char: '2', ring: null, section: 'ofAMERICA250', word: '250'},
                {char: '5', ring: null, section: 'ofAMERICA250', word: '250'},
                {char: '0', ring: null, section: 'ofAMERICA250', word: '250'}
            ];
            
            // Determine path style randomly for diversity - increased word-boundary bending probability
            const pathStyles = [
                'word-boundary-bending', 'word-boundary-bending', 'word-boundary-bending', // 30% chance
                'corner-to-outline', 'corner-to-outline', // 20% chance  
                'standard', 'standard', // 20% chance
                'zigzag', // 10% chance
                'straight-line', // 10% chance
                'mixed-diversity' // 10% chance
            ];
            const selectedStyle = pathStyles[Math.floor(Math.random() * pathStyles.length)];
            debugLog(`Selected path style: ${selectedStyle}`);
            
            let previousWord = 'UNITED'; // Starting word
            
            fullSequence.forEach((targetInfo, seqIndex) => {
                const targetChar = targetInfo.char;
                const targetRing = targetInfo.ring;
                const section = targetInfo.section;
                const currentWord = targetInfo.word;
                
                // Check if we're at a word boundary
                const isWordBoundary = (currentWord !== previousWord);
                if (isWordBoundary) {
                    debugLog(`Word boundary detected: ${previousWord} → ${currentWord}`);
                }
                
                debugLog(`Looking for ${targetChar} (${section}${targetRing ? `, ring ${targetRing}` : ''}, word: ${currentWord})...`);
                
                let candidateLetters = [];
                
                if (section === 'UNITEDSTATES') {
                    // Find pentagon letters in specific ring
                    candidateLetters = letters.filter(letter => 
                        letter.textContent === targetChar && 
                        letter.dataset.type === targetChar &&
                        parseInt(letter.dataset.ring) === targetRing &&
                        !usedLetters.has(letter.dataset.index)
                    );
                } else {
                    // Find tip letters (both outer and fill-in)
                    candidateLetters = letters.filter(letter => 
                        letter.textContent === targetChar && 
                        (letter.dataset.type === targetChar || letter.dataset.type === `fill-${targetChar}`) &&
                        (letter.dataset.pathType === 'outer' || letter.dataset.pathType === 'fill') &&
                        !usedLetters.has(letter.dataset.index)
                    );
                }
                
                debugLog(`Found ${candidateLetters.length} unused ${targetChar} candidates`);
                
                if (candidateLetters.length === 0) {
                    debugLog(`ERROR: No unused ${targetChar} letters found!`);
                    return;
                }
                
                // Find the closest letter to current position for TRUE continuity
                const currentX = parseFloat(currentLetter.style.left) + 12;
                const currentY = parseFloat(currentLetter.style.top) + 12;
                
                // Calculate distances and sort
                const letterDistances = candidateLetters.map(candidate => {
                    const candidateX = parseFloat(candidate.style.left) + 12;
                    const candidateY = parseFloat(candidate.style.top) + 12;
                    const distance = Math.sqrt((candidateX - currentX) ** 2 + (candidateY - currentY) ** 2);
                    
                    // Determine position type for diversity
                    let positionType = 'center';
                    if (candidate.dataset.pathType === 'outer') {
                        positionType = 'outer';
                    } else if (candidate.dataset.pathType === 'fill') {
                        // Calculate if it's corner, edge, or center
                        const tipIndex = parseInt(candidate.dataset.tip);
                        if (tipIndex !== undefined) {
                            const centerX = 1750;
                            const centerY = 1750;
                            const tipAngle = (tipIndex * 2 * Math.PI / 5) + (Math.PI / 2) + Math.PI;
                            const tipCenterX = centerX + 1100 * Math.cos(tipAngle);
                            const tipCenterY = centerY + 1100 * Math.sin(tipAngle);
                            
                            const perpAngle = tipAngle + Math.PI / 2;
                            const perpDist = Math.abs((candidateX - tipCenterX) * Math.cos(perpAngle) + (candidateY - tipCenterY) * Math.sin(perpAngle));
                            
                            if (perpDist > 80) positionType = 'corner';
                            else if (perpDist > 30) positionType = 'edge';
                            else positionType = 'center';
                        }
                    }
                    
                    return { letter: candidate, distance, positionType };
                }).sort((a, b) => a.distance - b.distance);
                
                // Apply path style-specific selection logic
                let selectedItem;
                
                if (selectedStyle === 'word-boundary-bending') {
                    // Word-boundary bending: Allow more freedom at word boundaries, strict within words
                    if (isWordBoundary) {
