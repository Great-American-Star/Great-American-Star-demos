            for (let i = 0; i < 10; i++) {
                const angle = (i * Math.PI / 5) + (Math.PI / 2) + Math.PI;
                const radius = (i % 2 === 0) ? outerRadius : innerRadius;
                const x = centerX + radius * Math.cos(angle);
                const y = centerY + radius * Math.sin(angle);
                points.push(`${x.toFixed(0)},${y.toFixed(0)}`);
            }
            
            const starOutline = document.getElementById('starOutline');
            starOutline.setAttribute('points', points.join(' '));
            debugLog("Star outline created");
        }

        function addFillInLetters() {
            debugLog("Adding fill-in letters...");
            const container = document.getElementById('starContainer');
            const centerX = 1750;
            const centerY = 1750;
            const outerRadius = 1610;
            const innerRadius = 615;
            
            let fillInCount = 0;
            
            // Function to add fill-in letters for a specific tip
            function addTipFillIn(tipIndex) {
                const tipAngle = (tipIndex * 2 * Math.PI / 5) + (Math.PI / 2) + Math.PI;
                const leftInnerAngle = tipAngle - (Math.PI / 5);
                const rightInnerAngle = tipAngle + (Math.PI / 5);
                
                const tipX = centerX + outerRadius * Math.cos(tipAngle);
                const tipY = centerY + outerRadius * Math.sin(tipAngle);
                
                const leftInnerX = centerX + innerRadius * Math.cos(leftInnerAngle);
                const leftInnerY = centerY + innerRadius * Math.sin(leftInnerAngle);
                const rightInnerX = centerX + innerRadius * Math.cos(rightInnerAngle);
                const rightInnerY = centerY + innerRadius * Math.sin(rightInnerAngle);
                
                // Offset adjustments per tip
                let offsetAdjustment = 0;
                if (tipIndex === 0) offsetAdjustment = -10;
                else if (tipIndex === 1) offsetAdjustment = -5;
                else if (tipIndex === 2) offsetAdjustment = -8;
                else if (tipIndex === 3) offsetAdjustment = -11;
                else if (tipIndex === 4) offsetAdjustment = -13;
                
                // Calculate unit vectors for both paths
                const leftDirX = tipX - leftInnerX;
                const leftDirY = tipY - leftInnerY;
                const leftPathLength = Math.sqrt(leftDirX * leftDirX + leftDirY * leftDirY);
                const leftUnitX = leftDirX / leftPathLength;
                const leftUnitY = leftDirY / leftPathLength;
                const leftPerpX = -leftUnitY;
                const leftPerpY = leftUnitX;
                
                const rightDirX = tipX - rightInnerX;
                const rightDirY = tipY - rightInnerY;
                const rightPathLength = Math.sqrt(rightDirX * rightDirX + rightDirY * rightDirY);
                const rightUnitX = rightDirX / rightPathLength;
                const rightUnitY = rightDirY / rightPathLength;
                const rightPerpX = -rightUnitY;
                const rightPerpY = rightUnitX;
                
                // Path perpendicular adjustments (your precise calibrations)
                let leftPerpOffset, rightPerpOffset;
                if (tipIndex === 0) { leftPerpOffset = 17; rightPerpOffset = -8; }      // Top tip
                else if (tipIndex === 1) { leftPerpOffset = 9; rightPerpOffset = -11; } // Upper Right tip
                else if (tipIndex === 2) { leftPerpOffset = 6; rightPerpOffset = -14; } // Lower Right tip
                else if (tipIndex === 3) { leftPerpOffset = 10; rightPerpOffset = -14; } // Lower Left tip
                else if (tipIndex === 4) { leftPerpOffset = 18; rightPerpOffset = -9; } // Upper Left tip
                
                // Letter sequence with counts and patriotic colors
                const letterSequence = [
                    {char: 'o', count: 19, offset: 40, size: 24, bold: false, color: '#0052CC'},  // Blue - of
                    {char: 'f', count: 18, offset: 70, size: 24, bold: false, color: '#0052CC'},  // Blue - of
                    {char: 'A', count: 17, offset: 105, size: 28, bold: true, color: '#DC143C'},  // Red - AMERICA
                    {char: 'M', count: 16, offset: 140, size: 28, bold: true, color: '#DC143C'},  // Red - AMERICA
                    {char: 'E', count: 15, offset: 175, size: 28, bold: true, color: '#DC143C'},  // Red - AMERICA
                    {char: 'R', count: 14, offset: 210, size: 28, bold: true, color: '#DC143C'},  // Red - AMERICA
                    {char: 'I', count: 13, offset: 245, size: 28, bold: true, color: '#DC143C'},  // Red - AMERICA
                    {char: 'C', count: 12, offset: 280, size: 28, bold: true, color: '#DC143C'},  // Red - AMERICA
                    {char: 'A', count: 11, offset: 315, size: 28, bold: true, color: '#DC143C'},  // Red - AMERICA
                    {char: '2', count: 10, offset: 350, size: 35, bold: true, color: '#FFD700'},  // Gold - 250
                    {char: '5', count: 9, offset: 380, size: 35, bold: true, color: '#FFD700'},   // Gold - 250
                    {char: '0', count: 8, offset: 410, size: 35, bold: true, color: '#FFD700'}    // Gold - 250
                ];
                
                letterSequence.forEach(letterData => {
                    // Calculate left path position with your precise adjustments
                    let leftLetterOffset = letterData.offset + offsetAdjustment;
                    
                    // Move paths 7 and 8 closer to "S" letters (your adjustment)
                    if (tipIndex === 3) { // Lower Left tip (paths 7 and 8)
                        leftLetterOffset -= 4; // Move 4px closer to "S"
                    }
                    
                    // Move paths 9 and 10 closer to "S" letters (your adjustment)
                    if (tipIndex === 4) { // Upper Left tip (paths 9 and 10)
                        leftLetterOffset -= 3; // Move 3px closer to "S"
                    }
                    
                    let leftLetterX = leftInnerX + leftUnitX * leftLetterOffset + leftPerpX * leftPerpOffset;
                    let leftLetterY = leftInnerY + leftUnitY * leftLetterOffset + leftPerpY * leftPerpOffset;
                    
                    // Calculate right path position with your precise adjustments
                    let rightLetterOffset = letterData.offset + offsetAdjustment;
                    
                    // Move paths 7 and 8 closer to "S" letters (your adjustment)
                    if (tipIndex === 3) { // Lower Left tip (paths 7 and 8)
                        rightLetterOffset -= 4; // Move 4px closer to "S"
                    }
                    
                    // Move paths 9 and 10 closer to "S" letters (your adjustment)
                    if (tipIndex === 4) { // Upper Left tip (paths 9 and 10)
                        rightLetterOffset -= 3; // Move 3px closer to "S"
                    }
                    
                    let rightLetterX = rightInnerX + rightUnitX * rightLetterOffset + rightPerpX * rightPerpOffset;
                    let rightLetterY = rightInnerY + rightUnitY * rightLetterOffset + rightPerpY * rightPerpOffset;
                    
                    // Special adjustments for "250" in specific paths (your precise calibrations)
                    if (tipIndex === 1 && (letterData.char === '2' || letterData.char === '5' || letterData.char === '0')) {
                        // Path 3 (upper right tip, left side): move outward by 4px (your calibrated value)
                        leftLetterX += leftPerpX * (-4);
                        leftLetterY += leftPerpY * (-4);
                    }
                    if (tipIndex === 4 && (letterData.char === '2' || letterData.char === '5' || letterData.char === '0')) {
                        // Path 10 (upper left tip, right side): move outward by 2px (your calibrated value)
                        rightLetterX += rightPerpX * 2;
                        rightLetterY += rightPerpY * 2;
                    }
                    
                    // Create fill-in letters equally spaced between the exact outer positions
                    for (let i = 1; i <= letterData.count; i++) {
                        const t = i / (letterData.count + 1);
                        
                        const x = leftLetterX + t * (rightLetterX - leftLetterX);
                        const y = leftLetterY + t * (rightLetterY - leftLetterY);
                        
                        const letter = document.createElement('div');
                        letter.className = 'letter';
                        letter.textContent = letterData.char;
                        letter.style.left = (x - letterData.size/2) + 'px';
                        letter.style.top = (y - letterData.size/2) + 'px';
                        letter.style.color = letterData.color;
                        letter.style.fontSize = letterData.size + 'px';
                        letter.style.fontWeight = letterData.bold ? 'bold' : 'normal';
                        letter.dataset.index = letters.length;
                        letter.dataset.type = 'fill-' + letterData.char;
                        letter.dataset.tip = tipIndex;
                        letter.dataset.pathType = 'fill';
                        
                        // Add special visual effects for fill-in letters based on position
                        const centerX = 1750;
                        const centerY = 1750;
                        const tipAngle = (tipIndex * 2 * Math.PI / 5) + (Math.PI / 2) + Math.PI;
                        const tipCenterX = centerX + 1100 * Math.cos(tipAngle);
                        const tipCenterY = centerY + 1100 * Math.sin(tipAngle);
                        
                        // Distance from tip center line
                        const perpAngle = tipAngle + Math.PI / 2;
                        const perpDist = Math.abs((x - tipCenterX) * Math.cos(perpAngle) + (y - tipCenterY) * Math.sin(perpAngle));
                        
                        // Distance from pentagon center
                        const distFromCenter = Math.sqrt((x - centerX) ** 2 + (y - centerY) ** 2);
                        
                        if (perpDist > 80) {
                            letter.classList.add('corner-letter'); // Far from center line = corner-ish
                        } else if (perpDist > 30 || distFromCenter > 1400) {
                            letter.classList.add('edge-letter'); // Medium distance = edge
                        }
                        // Center letters get no special class (normal appearance)
                        
                        container.appendChild(letter);
                        letters.push(letter);
                        fillInCount++;
                    }
                });
            }
            
            // Add fill-in letters for all tips
            addTipFillIn(0); // Top tip
            addTipFillIn(1); // Upper right tip
            addTipFillIn(2); // Lower right tip
            addTipFillIn(3); // Lower left tip
            addTipFillIn(4); // Upper left tip
            
            debugLog(`Fill-in letters added: ${fillInCount} letters`);
        }

        // Initialize everything when page loads
        window.addEventListener('DOMContentLoaded', function() {
            debugLog("=== STARTING INITIALIZATION ===");
            createUNITEDSTATES();
            addOfAmerica250Paths();
            addFillInLetters();
            createStarOutline();
            
            // Update info display
            document.getElementById('totalCount').textContent = `Total: ${letters.length} letters`;
            
            debugLog(`=== INITIALIZATION COMPLETE: ${letters.length} total letters ===`);
        });

        // Add mouse wheel zoom
        document.addEventListener('wheel', (e) => {
            e.preventDefault();
            if (e.deltaY < 0) {
                zoomIn();
            } else {
                zoomOut();
            }
        });
</script>
